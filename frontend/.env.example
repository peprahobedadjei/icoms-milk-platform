# Copy this file to .env.local and fill in values. .env.local is gitignored.

# Firebase Web config (from Firebase console > Project settings > Your apps).
# These are public client identifiers (they ship in the browser bundle); security
# is enforced by Firestore rules + API-key restrictions, not by hiding them.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Bootstrap admins: emails allowed to self-create an admin account on first
# sign-in (comma-separated).
NEXT_PUBLIC_BOOTSTRAP_ADMIN_EMAIL=admin@icoms.app

# Default admin credentials pre-filled on the login form (dev convenience).
# Firebase requires a valid email and a password of at least 6 characters.
# CHANGE / REMOVE before any public deployment.
NEXT_PUBLIC_DEFAULT_ADMIN_EMAIL=admin@icoms.app
NEXT_PUBLIC_DEFAULT_ADMIN_PASSWORD=admin123

# EmailJS (invitation emails). Leave blank to show credentials for manual sending.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Python inference backend URL.
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8020
